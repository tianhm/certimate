{
  "$ns": "login",

  "form": {
    "username": {
      "label": "Username",
      "placeholder": "Username/Email",
      "errmsg": {
        "invalid": "Please enter a valid email address"
      }
    },
    "password": {
      "label": "Password",
      "placeholder": "Password",
      "errmsg": {
        "invalid": "Password should be at least 10 characters"
      }
    },
    "submit": {
      "button": "Log-in"
    }
  }
}
